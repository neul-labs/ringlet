{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/nicegui/json_schema/tauri-v2.json",
  "productName": "Ringlet",
  "version": "0.1.0",
  "identifier": "com.neullabs.ringlet",
  "build": {
    "frontendDist": "../../ringlet-ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../../ringlet-ui && npm run dev",
    "beforeBuildCommand": "cd ../../ringlet-ui && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Ringlet",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["ringletd"]
  }
}
